# ── AI proxy (server/index.mjs) ──────────────────────────────────────────────
# Anthropic API key. Server-side ONLY — never prefix with VITE_ (that would
# bundle it into the browser build and expose it publicly).
ANTHROPIC_API_KEY=sk-ant-...

# Port the proxy listens on (frontend VITE_API_URL must point here).
PORT=3001

# Browser origin allowed to call the proxy (CORS).
# Dev default below; in PRODUCTION this is REQUIRED (no fallback) — set it to
# your real frontend origin, e.g. https://app.example.de
ALLOWED_ORIGIN=http://localhost:5173

# ── Auth (PRODUCTION-REQUIRED) ────────────────────────────────────────────────
# Secret that signs the HMAC session tokens. REQUIRED in production and must be
# >= 32 characters. Without it the prod server refuses to start (fail-fast).
# Generate one, e.g.:  openssl rand -hex 32
# In dev an ephemeral secret is auto-generated (sessions reset on restart).
EK_AUTH_SECRET=

# ── Magic-link email delivery (optional) ──────────────────────────────────────
# Without these, dev logs the login link to the console; production logs a
# delivery failure (and never logs the raw token). Point the webhook at your
# transactional email provider / relay; it receives { to, from, subject, text, link }.
# EK_MAIL_WEBHOOK_URL=https://mail.example.de/send
# EK_MAIL_WEBHOOK_AUTH=Bearer xxxxx
# EK_MAIL_FROM=no-reply@example.de

# ── Dev only ──────────────────────────────────────────────────────────────────
# Trust the X-User-Email header (role switcher) for local development. NEVER set
# this in production. `npm run dev:api` enables it automatically.
# EK_DEV_HEADERS=1

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Base URL the browser uses to reach the proxy. Must NOT contain any secret.
VITE_API_URL=http://localhost:3001

# Production start (server):
#   NODE_ENV=production EK_AUTH_SECRET=<32+ chars> ALLOWED_ORIGIN=https://app.example.de \
#     ANTHROPIC_API_KEY=sk-ant-... npm start
